---
import '../styles/global.css';

const baseUrl = import.meta.env.BASE_URL;
const leafImages = [
  `${baseUrl}img/hoja1.jpeg`,
  `${baseUrl}img/hoja2.jpeg`,
  `${baseUrl}img/hoja3.jpeg`,
  `${baseUrl}img/hoja4.jpeg`,
  `${baseUrl}img/hoja5.jpeg`,
  `${baseUrl}img/hoja6.jpeg`,
  `${baseUrl}img/hoja7.jpeg`,
  `${baseUrl}img/hoja8.jpeg`,
];
---

<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Sergio y Carolina te invitan a celebrar su boda con una experiencia elegante y emotiva."
    />
    <title>Sergio y Carolina - Nuestro Casamiento</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.12.0/dist/cdn.min.js"></script>
  </head>
  <body class="min-h-screen bg-ivory text-slate-700 antialiased leading-relaxed pt-20">
    <header class="fixed top-0 z-50 w-full border-b border-white/50 bg-ivory/95 backdrop-blur-md" x-data="{ open: false }">
      <div class="mx-auto flex h-20 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
        <a href="#home" class="font-serif text-3xl font-semibold tracking-[0.2em] text-slate-900">S & C</a>
        <button @click="open = !open" class="text-3xl text-slate-900 lg:hidden">☰</button>
        <nav class="hidden gap-8 lg:flex">
          <a href="#home" class="text-sm uppercase tracking-[0.15em] text-slate-700 transition hover:text-sage">Inicio</a>
          <a href="#story" class="text-sm uppercase tracking-[0.15em] text-slate-700 transition hover:text-sage">Nuestra historia</a>
          <a href="#details" class="text-sm uppercase tracking-[0.15em] text-slate-700 transition hover:text-sage">Detalles</a>
          <a href="#itinerary" class="text-sm uppercase tracking-[0.15em] text-slate-700 transition hover:text-sage">Cronograma</a>
          <a href="#gallery" class="text-sm uppercase tracking-[0.15em] text-slate-700 transition hover:text-sage">Galería</a>
          <a href="#rsvp" class="text-sm uppercase tracking-[0.15em] text-slate-700 transition hover:text-sage">Confirmar asistencia</a>
        </nav>
      </div>
      <div x-show="open" x-transition class="lg:hidden">
        <div class="border-t border-gray-200 bg-ivory/95 px-4 py-4 backdrop-blur-sm">
          <div class="flex flex-col gap-2 text-sm uppercase tracking-[0.15em] text-slate-700">
            <a href="#home" class="block rounded-full px-4 py-3 transition hover:bg-sage/10">Inicio</a>
            <a href="#story" class="block rounded-full px-4 py-3 transition hover:bg-sage/10">Nuestra historia</a>
            <a href="#details" class="block rounded-full px-4 py-3 transition hover:bg-sage/10">Detalles</a>
            <a href="#itinerary" class="block rounded-full px-4 py-3 transition hover:bg-sage/10">Cronograma</a>
            <a href="#gallery" class="block rounded-full px-4 py-3 transition hover:bg-sage/10">Galería</a>
            <a href="#rsvp" class="block rounded-full px-4 py-3 transition hover:bg-sage/10">Confirmar asistencia</a>
          </div>
        </div>
      </div>
    </header>

    <main>
      <section id="home" tabindex="-1" class="relative flex min-h-screen items-center justify-center overflow-hidden">
        <div class="absolute inset-0 bg-cover bg-center" style={`background-image: url('${baseUrl}img/hero.jpg');`}></div>
        <div class="absolute inset-0 bg-gradient-to-b from-black/50 via-black/35 to-black/60"></div>
        <div class="leaves pointer-events-none" aria-hidden="true">
          {leafImages.map((image, index) => (
            <span
              class={`leaf leaf-${index + 1}`}
              style={`background-image: url('${image}');`}
            />
          ))}
        </div>
        <div class="relative z-10 w-full px-4 py-24 text-center text-white sm:px-6 lg:px-8">
          <div class="mx-auto max-w-4xl rounded-[2rem] border border-white/20 bg-white/10 p-8 backdrop-blur-sm sm:p-12">
            <p class="mb-4 text-sm uppercase tracking-[0.4em] text-white/80">Nos casamos</p>
            <h1 class="font-serif text-5xl leading-tight sm:text-6xl lg:text-8xl">Sergio & Carolina</h1>
            <p class="mx-auto mt-6 max-w-2xl text-lg text-white/90 sm:text-xl">Una celebración llena de amor, recuerdos y el comienzo de una nueva historia juntos.</p>
            <div id="countdown" class="mt-10 grid grid-cols-2 gap-4 text-center sm:grid-cols-4">
              <div class="rounded-2xl border border-white/30 bg-white/15 p-4"><div class="text-3xl font-semibold" data-unit="days">00</div><div class="mt-1 text-sm uppercase tracking-[0.2em]">Días</div></div>
              <div class="rounded-2xl border border-white/30 bg-white/15 p-4"><div class="text-3xl font-semibold" data-unit="hours">00</div><div class="mt-1 text-sm uppercase tracking-[0.2em]">Horas</div></div>
              <div class="rounded-2xl border border-white/30 bg-white/15 p-4"><div class="text-3xl font-semibold" data-unit="minutes">00</div><div class="mt-1 text-sm uppercase tracking-[0.2em]">Min</div></div>
              <div class="rounded-2xl border border-white/30 bg-white/15 p-4"><div class="text-3xl font-semibold" data-unit="seconds">00</div><div class="mt-1 text-sm uppercase tracking-[0.2em]">Seg</div></div>
            </div>
            
          </div>
        </div>
      </section>

      <section id="story" class="section-shell py-24">
        <div class="soft-card overflow-hidden p-0">
          <div class="relative">
            <img src={`${baseUrl}img/hero.jpg`} alt="Sergio y Carolina" class="h-80 w-full object-cover" />
            <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/60"></div>
            <div class="absolute bottom-4 left-4 rounded-full border border-white/30 bg-white/10 px-4 py-2 text-sm uppercase tracking-[0.3em] text-white backdrop-blur-sm">Nuestra historia</div>
          </div>
          <div class="p-8 sm:p-10 transition duration-300 hover:-translate-y-1 hover:shadow-[0_30px_80px_rgba(0,0,0,0.12)]">
            <p class="text-sm uppercase tracking-[0.3em] text-botanical">Nuestra historia</p>
            <h2 class="mt-4 font-serif text-4xl text-botanical sm:text-5xl">Amor, tiempo y recuerdos</h2>
            <p class="mt-6 text-lg text-gray-700">Lo que comenzó con una conversación sencilla se convirtió en una historia hermosa. Cada paso nos llevó a este día, cargado de emoción, familia y esperanza.</p>
            <p class="mt-4 text-lg text-gray-700">Queremos compartirlo contigo con una ceremonia íntima, un ambiente acogedor y momentos que recordaremos por siempre.</p>
            <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
              <div class="rounded-[1.5rem] border border-gray-200 bg-white/90 p-5 text-center transition hover:-translate-y-1 hover:shadow-md">
                <p class="text-sm uppercase tracking-[0.3em] text-botanical">Dress code</p>
                <p class="mt-3 text-sm text-gray-700">Elegante y sofisticado</p>
              </div>
              <div class="rounded-[1.5rem] border border-gray-200 bg-white/90 p-5 text-center transition hover:-translate-y-1 hover:shadow-md">
                <p class="text-sm uppercase tracking-[0.3em] text-botanical">Estacionamiento</p>
                <p class="mt-3 text-sm text-gray-700">Disponible</p>
              </div>
              <div class="rounded-[1.5rem] border border-gray-200 bg-white/90 p-5 text-center transition hover:-translate-y-1 hover:shadow-md">
                <p class="text-sm uppercase tracking-[0.3em] text-botanical">Co-Invitados</p>
                <p class="mt-3 text-sm text-gray-700">Bienvenidos con invitación</p>
              </div>
              <div class="rounded-[1.5rem] border border-gray-200 bg-white/90 p-5 text-center transition hover:-translate-y-1 hover:shadow-md">
                <p class="text-sm uppercase tracking-[0.3em] text-botanical">Fotografía</p>
                <p class="mt-3 text-sm text-gray-700">Nombre del fotógrafo</p>
              </div>
            </div>
          </div>
        </div>
      </section>
      <section class="section-shell pb-24">
        <div class="mb-10 text-center">
          <p class="text-sm uppercase tracking-[0.3em] text-botanical">Información importante</p>
          <h2 class="mt-3 font-serif text-4xl text-botanical sm:text-5xl">Todo lo que necesitas saber</h2>
        </div>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          <div class="rounded-[1.5rem] border border-gray-200 bg-white/90 p-6 text-center transition hover:-translate-y-1 hover:shadow-md">
            <p class="text-sm uppercase tracking-[0.3em] text-botanical">Clima</p>
            <p class="mt-3 text-sm text-gray-700">Fresco, lleva abrigo ligero</p>
          </div>
          <div class="rounded-[1.5rem] border border-gray-200 bg-white/90 p-6 text-center transition hover:-translate-y-1 hover:shadow-md">
            <p class="text-sm uppercase tracking-[0.3em] text-botanical">Regalos</p>
            <p class="mt-3 text-sm text-gray-700">Tu presencia es el mejor regalo</p>
          </div>
          <div class="rounded-[1.5rem] border border-gray-200 bg-white/90 p-6 text-center transition hover:-translate-y-1 hover:shadow-md">
            <p class="text-sm uppercase tracking-[0.3em] text-botanical">WiFi</p>
            <p class="mt-3 text-sm text-gray-700">Red disponible en el lugar</p>
          </div>
          <div class="rounded-[1.5rem] border border-gray-200 bg-white/90 p-6 text-center transition hover:-translate-y-1 hover:shadow-md">
            <p class="text-sm uppercase tracking-[0.3em] text-botanical">Niños</p>
            <p class="mt-3 text-sm text-gray-700">Evento familiar y acogedor</p>
          </div>
        </div>
      </section>

      <section id="details" class="section-shell pb-24">
        <div class="mb-10 text-center">
          <p class="text-sm uppercase tracking-[0.3em] text-botanical">Detalles</p>
          <h2 class="mt-3 font-serif text-4xl text-botanical sm:text-5xl">Ceremonia y celebración</h2>
        </div>
        <div class="grid gap-6 md:grid-cols-2">
          <div class="soft-card p-8">
            <div class="mb-4 inline-flex rounded-full bg-botanical/10 px-3 py-1 text-sm font-semibold text-botanical">15:00 hs</div>
            <h3 class="font-serif text-3xl text-botanical">Ceremonia</h3>
            <p class="mt-4 text-lg text-gray-700">Nos reuniremos a las 15:00 horas para compartir el momento más importante de nuestro camino.</p>
            <ul class="mt-6 space-y-3 text-gray-700">
              <li>• Lugar: Parque de las naciones</li>
              <li>• Salón: colectividad paraguaya</li>
              <li>• Vestimenta: Formal</li>
              <li>• Estacionamiento disponible</li>
            </ul>
          </div>
          <div class="soft-card p-8">
            <div class="mb-4 inline-flex rounded-full bg-botanical/10 px-3 py-1 text-sm font-semibold text-botanical">18:00 hs</div>
            <h3 class="font-serif text-3xl text-botanical">Recepción</h3>
            <p class="mt-4 text-lg text-gray-700">Después de la ceremonia, habrá música, buena comida y un ambiente para disfrutar en familia.</p>
            <ul class="mt-6 space-y-3 text-gray-700">
              <li>• Comenzamos a las 18:00</li>
              <li>• Baile y té</li>
              <li>• Ambiente íntimo y acogedor</li>
            </ul>
          </div>
        </div>
      </section>

      <section id="itinerary" class="section-shell pb-24">
        <div class="soft-card overflow-hidden">
          <div class="grid gap-0 lg:grid-cols-[0.95fr_1.05fr]">
            <div class="bg-cover bg-center p-10 sm:p-14 lg:min-h-[360px]" style="background-image: url('img/hero.jpg');"></div>
            <div class="p-8 sm:p-10">
              <p class="text-sm uppercase tracking-[0.3em] text-botanical">Cronograma</p>
              <h2 class="mt-3 font-serif text-4xl text-botanical">Un día para recordar</h2>
              <div class="mt-8 space-y-6">
                <div class="border-b border-gray-100 pb-4">
                  <p class="text-sm font-semibold uppercase tracking-[0.25em] text-botanical">15:00</p>
                  <p class="mt-2 text-lg text-gray-700">Ceremonia</p>
                </div>
                <div class="border-b border-gray-100 pb-4">
                  <p class="text-sm font-semibold uppercase tracking-[0.25em] text-botanical">18:00</p>
                  <p class="mt-2 text-lg text-gray-700">Recepción</p>
                </div>
                <div>
                  <p class="text-sm font-semibold uppercase tracking-[0.25em] text-botanical">21:00</p>
                  <p class="mt-2 text-lg text-gray-700">Baile y celebración</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="gallery" class="section-shell pb-24">
        <div class="soft-card overflow-hidden p-8 sm:p-10">
          <div class="mb-8 text-center">
            <p class="text-sm uppercase tracking-[0.3em] text-botanical">Galería</p>
            <h2 class="mt-3 font-serif text-4xl text-botanical sm:text-5xl">Nuestros momentos favoritos</h2>
          </div>
          <div class="grid gap-4 md:grid-cols-3">
            <div class="group h-72 overflow-hidden rounded-[1.5rem] bg-cover bg-center transition duration-300 hover:scale-[1.02]" style="background-image: url('img/hero.jpg');"></div>
            <div class="group h-72 overflow-hidden rounded-[1.5rem] bg-cover bg-center transition duration-300 hover:scale-[1.02]" style="background-image: url('img/hero.jpg');"></div>
            <div class="group h-72 overflow-hidden rounded-[1.5rem] bg-cover bg-center transition duration-300 hover:scale-[1.02]" style="background-image: url('img/hero.jpg');"></div>
          </div>
        </div>
      </section>

      <section class="section-shell pb-24">
        <div class="soft-card overflow-hidden p-8 sm:p-10">
          <div class="grid gap-8 lg:grid-cols-[0.95fr_1.05fr] lg:items-center">
            <div>
              <p class="text-sm uppercase tracking-[0.3em] text-botanical">Ubicación</p>
              <h2 class="mt-3 font-serif text-4xl text-botanical">Estamos esperándote</h2>
              <p class="mt-4 text-lg text-gray-700">El evento será en un lugar especial, con ambiente íntimo y hermoso para compartir este día tan importante.</p>
              <div class="mt-6 rounded-[1.5rem] bg-botanical/10 p-6 text-gray-700">
                <p class="font-semibold text-botanical">Salón de eventos elegante</p>
                <p class="mt-2">Parque de las naciones, Obera</p>
                <p class="mt-1">Estacionamiento gratuito y acceso sencillo</p>
              </div>
            </div>
            <div class="overflow-hidden rounded-[1.5rem] border border-gray-100">
              <iframe
                src="https://www.google.com/maps?q=Parque+de+las+Naciones+Ober%C3%A1&output=embed"
                class="h-72 w-full"
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title="Mapa del lugar"
              ></iframe>
            </div>
          </div>
        </div>
      </section>

      <section id="rsvp" class="section-shell pb-24">
        <div class="grid gap-8 lg:grid-cols-[0.95fr_1.05fr]">
          <div class="soft-card p-8 sm:p-10 transition duration-300 hover:-translate-y-1 hover:shadow-[0_30px_80px_rgba(0,0,0,0.12)]">
            <p class="text-sm uppercase tracking-[0.3em] text-botanical">RSVP</p>
            <h2 class="mt-3 font-serif text-4xl text-botanical">Confirma tu asistencia</h2>
            <p class="mt-4 text-lg text-gray-700">Tu presencia hará que este día sea aún más especial. Nos encantaría compartirlo contigo.</p>
            <div class="mt-8 rounded-[1.5rem] bg-botanical/10 p-6 text-gray-700">
              <p class="font-semibold text-botanical">Fecha límite</p>
              <p class="mt-2">Por favor responde antes del 15 de septiembre.</p>
            </div>
            <div class="mt-8 grid gap-4 sm:grid-cols-2">
              <div class="rounded-[1.5rem] border border-gray-200 bg-white/90 p-6 text-center transition hover:-translate-y-1 hover:shadow-md">
                <p class="text-sm uppercase tracking-[0.3em] text-botanical">Ceremonia</p>
                <p class="mt-3 text-sm text-gray-700">15:00 hrs</p>
              </div>
              <div class="rounded-[1.5rem] border border-gray-200 bg-white/90 p-6 text-center transition hover:-translate-y-1 hover:shadow-md">
                <p class="text-sm uppercase tracking-[0.3em] text-botanical">Recepción</p>
                <p class="mt-3 text-sm text-gray-700">18:00 hrs</p>
              </div>
            </div>
          </div>
          <div class="soft-card p-8 sm:p-10 transition duration-300 hover:-translate-y-1 hover:shadow-[0_30px_80px_rgba(0,0,0,0.12)]">
            <form class="space-y-4">
              <div>
                <label class="mb-2 block text-sm font-semibold text-gray-700">Nombre completo</label>
                <input class="w-full rounded-2xl border border-gray-200 bg-white px-4 py-3 outline-none transition focus:border-botanical" placeholder="Nombre completo" />
              </div>
              <div>
                <label class="mb-2 block text-sm font-semibold text-gray-700">Dirección de correo electrónico</label>
                <input class="w-full rounded-2xl border border-gray-200 bg-white px-4 py-3 outline-none transition focus:border-botanical" placeholder="email@ejemplo.com" type="email" />
              </div>
              <div>
                <label class="mb-2 block text-sm font-semibold text-gray-700">Número de invitados</label>
                <input class="w-full rounded-2xl border border-gray-200 bg-white px-4 py-3 outline-none transition focus:border-botanical" placeholder="Cantidad de invitados" type="number" min="0" />
              </div>
              <div class="space-y-3 rounded-[1.5rem] border border-gray-200 bg-white/90 p-4">
                <p class="text-sm font-semibold uppercase tracking-[0.25em] text-botanical">¿Asistirás?</p>
                <label class="inline-flex items-center gap-3 text-gray-700">
                  <input type="radio" name="asistire" value="acepta" class="h-4 w-4 text-botanical" />
                  Acepta
                </label>
                <label class="inline-flex items-center gap-3 text-gray-700">
                  <input type="radio" name="asistire" value="declina" class="h-4 w-4 text-botanical" />
                  Lamentablemente declina
                </label>
              </div>
              <div>
                <label class="mb-2 block text-sm font-semibold text-gray-700">Mensaje opcional</label>
                <textarea class="min-h-[120px] w-full rounded-2xl border border-gray-200 bg-white px-4 py-3 outline-none transition focus:border-botanical" placeholder="Escribe un mensaje opcional"></textarea>
              </div>
              <button class="w-full rounded-full bg-botanical px-6 py-3 text-sm font-semibold text-white transition hover:bg-sage">Confirmar asistencia</button>
            </form>
          </div>
        </div>
      </section>
      <section id="contact" class="section-shell pb-24">
        <div class="mb-10 text-center">
          <p class="text-sm uppercase tracking-[0.3em] text-botanical">Contacto</p>
          <h2 class="mt-3 font-serif text-4xl text-botanical sm:text-5xl">Nuestro equipo</h2>
        </div>
        <div class="grid gap-8 lg:grid-cols-2">
          <div class="soft-card p-8 sm:p-10">
            <div class="flex flex-col items-center gap-6 text-center sm:flex-row sm:text-left">
              <div class="h-32 w-32 overflow-hidden rounded-full border border-gray-200">
                <img src="img/hero.jpg" alt="Tomas Aguilar" class="h-full w-full object-cover" />
              </div>
              <div>
                <p class="text-lg font-semibold text-botanical">Tomas Aguilar</p>
                <p class="text-sm text-gray-700">Organizador</p>
                <p class="mt-4 text-sm text-gray-600">tomas@example.com</p>
                <p class="text-sm text-gray-600">+54 9 11 0000 0000</p>
              </div>
            </div>
          </div>
          <div class="soft-card p-8 sm:p-10">
            <div class="flex flex-col items-center gap-6 text-center sm:flex-row sm:text-left">
              <div class="h-32 w-32 overflow-hidden rounded-full border border-gray-200">
                <img src="img/hero.jpg" alt="Sergio y Carolina" class="h-full w-full object-cover" />
              </div>
              <div>
                <p class="text-lg font-semibold text-botanical">Sergio & Carolina</p>
                <p class="text-sm text-gray-700">Los novios</p>
                <p class="mt-4 text-sm text-gray-600">email@ejemplo.com</p>
                <p class="text-sm text-gray-600">+54 9 11 0000 0000</p>
              </div>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="border-t border-gray-200 bg-white/70 py-10">
      <div class="section-shell flex flex-col items-center justify-between gap-4 text-center text-sm text-gray-600 sm:flex-row">
        <p>© 2026 Sergio y Carolina. Gracias por acompañarnos.</p>
        <p>Con amor, siempre.</p>
      </div>
    </footer>

    <script>
      const targetTime = new Date('2026-10-03T15:00:00').getTime();
      const container = document.getElementById('countdown');

      setInterval(() => {
        const now = Date.now();
        const d = targetTime - now;
        if (d < 0) return;

        const days = Math.floor(d / (1000 * 60 * 60 * 24));
        const hours = Math.floor((d / (1000 * 60 * 60)) % 24);
        const minutes = Math.floor((d / (1000 * 60)) % 60);
        const seconds = Math.floor((d / 1000) % 60);

        container.querySelector('[data-unit="days"]').textContent = days.toString().padStart(2, '0');
        container.querySelector('[data-unit="hours"]').textContent = hours.toString().padStart(2, '0');
        container.querySelector('[data-unit="minutes"]').textContent = minutes.toString().padStart(2, '0');
        container.querySelector('[data-unit="seconds"]').textContent = seconds.toString().padStart(2, '0');
      }, 1000);
    </script>

    <div x-data="{ playing: false, audio: null }" class="fixed bottom-5 right-5 z-50">
      <audio id="musica-boda" src="mus/ambiente.mp3" loop></audio>
      <button
        @click="
          audio = document.getElementById('musica-boda');
          if (playing) { audio.pause(); } else { audio.play(); }
          playing = !playing;
        "
        class="flex h-11 w-11 items-center justify-center rounded-full bg-botanical text-ivory shadow-lg transition hover:bg-sage"
        aria-label="Reproducir música"
      >
        <span class="sr-only" x-text="playing ? 'Pausar música' : 'Reproducir música'"></span>
        <span class="text-xl" x-text="playing ? '⏸' : '▶'" aria-hidden="true"></span>
      </button>
    </div>

    <script>
      const audioEl = document.getElementById('musica-boda');
      const toggleAudio = () => {
        if (!audioEl) return;
        audioEl.play().catch(() => {});
      };
      window.addEventListener('load', toggleAudio);
      document.addEventListener('visibilitychange', () => {
        if (document.visibilityState === 'visible' && audioEl && audioEl.paused) {
          audioEl.play().catch(() => {});
        }
      });
    </script>
  </body>
</html>